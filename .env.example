# Copy to .env (gitignored) and fill in what you have. Every key is optional:
# Assay runs fully offline by default. Keys only widen what it can fetch.

# --- SEC EDGAR (Tier 1, filings) ---
# EDGAR's fair-access policy requires a descriptive User-Agent with contact info.
ASSAY_SEC_USER_AGENT=assay/0.1 (your-email@example.com)

# --- FRED (Tier 1, macro: risk-free rate for the discount rate) ---
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Prices (Tier 0). Default is yahoo: free, no key, no signup. ---
ASSAY_PRICE_PROVIDER=yahoo         # yahoo (keyless) | tiingo (optional key) | offline
# Optional upgrade only, never required. Free token: https://www.tiingo.com
TIINGO_API_KEY=

# --- Analyst targets (Tier 2, comparison only) ---
FMP_API_KEY=
FINNHUB_API_KEY=

# --- Optional LLM narrator (prose only; numbers are always deterministic) ---
ASSAY_LLM_PROVIDER=offline        # offline | anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
